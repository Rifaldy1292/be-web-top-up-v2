{
	"info": {
		"name": "Games API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "List Games",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/games",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"games"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Game",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/games/1",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"games",
						"1"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Game by Slug",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/games/slug/mobile-legends",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"games",
						"slug",
						"mobile-legends"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create Game",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "gameName",
							"value": "Mobile Legends",
							"type": "text"
						},
						{
							"key": "slug",
							"value": "mobile-legends",
							"type": "text"
						},
						{
							"key": "status",
							"value": "true",
							"type": "text"
						},
						{
							"key": "image",
							"type": "file",
							"src": []
						},
						{
							"key": "banner",
							"type": "file",
							"src": []
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/games",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"games"
					]
				}
			},
			"response": []
		},
		{
			"name": "Update Game",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "PATCH",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"gameName\": \"Mobile Legends Updated\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/games/1",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"games",
						"1"
					]
				}
			},
			"response": []
		},
		{
			"name": "Delete Game",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/games/1",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"games",
						"1"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000/api",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		}
	]
}
